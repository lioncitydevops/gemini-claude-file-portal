# Copy this file to .env.local and fill in your API keys

# Google AI Studio - https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_api_key_here

# Anthropic Console - https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_claude_api_key_here

# Vercel Blob is automatically configured when you add it to your project.
# For local dev without Blob, files are stored in .upload-storage/
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token_here

# Optional: set to "private" if your Vercel Blob store is private (default: public)
# BLOB_STORE_ACCESS=private
